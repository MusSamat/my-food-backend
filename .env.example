# ═══ Server ═══
PORT=4000
NODE_ENV=development

# ═══ PostgreSQL ═══
DB_HOST=localhost
DB_PORT=5432
DB_NAME=food_delivery
DB_USER=postgres
DB_PASSWORD=your_db_password

# ═══ JWT (admin auth) ═══
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# ═══ Telegram ═══
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
MINI_APP_URL=https://your-domain.com/menu

# ═══ Finik Pay ═══
FINIK_API_URL=https://api.finik.kg
FINIK_API_KEY=your_finik_api_key
FINIK_SECRET_KEY=your_finik_secret_key
FINIK_CALLBACK_URL=https://api.your-domain.com/api/webhooks/finik
FINIK_REDIRECT_URL=https://your-domain.com/order-status

# ═══ Printer ═══
PRINTER_TYPE=browser
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# ═══ Uploads ═══
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ═══ Restaurant Info ═══
RESTAURANT_NAME=Your Restaurant
RESTAURANT_ADDRESS=г. Бишкек, ул. Example 123
RESTAURANT_PHONE=+996 555 123 456
